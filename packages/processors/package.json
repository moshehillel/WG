{
  "name": "@white-glove/processors",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./handlers/*": {
      "types": "./dist/handlers/*.d.ts",
      "import": "./dist/handlers/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.716.0",
    "@aws-sdk/client-s3": "^3.716.0",
    "@aws-sdk/client-sns": "^3.716.0",
    "@aws-sdk/lib-dynamodb": "^3.716.0",
    "@white-glove/hha-client": "*",
    "@white-glove/shared": "*",
    "csv-parse": "^5.6.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.146",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
