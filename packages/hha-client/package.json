{
  "name": "@white-glove/hha-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "sandbox:smoke": "tsx src/sandbox-smoke.ts",
    "sandbox:create-patient": "node scripts/create-patient-sandbox.mjs",
    "sandbox:session-flow": "tsx src/sandbox-session-flow.ts"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.716.0",
    "@white-glove/shared": "*",
    "fast-xml-parser": "^4.5.1"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
