# HHA SOAP — SANDBOX ONLY until go-live is approved
# Do not use https://app.hhaexchange.com here yet.
HHA_BASE_URL=https://sandbox1.hhaexchange.com/Integration/ENT/V1.8/ws.asmx
HHA_APP_NAME=
HHA_APP_SECRET=
HHA_APP_KEY=
HHA_OFFICE_ID=1025
HHA_COORDINATOR_ID=81103
# Optional CreatePatient defaults (sandbox patient 958000 setup)
# HHA_SOURCE_OF_ADMISSION=9300
# HHA_MOBILITY_STATUS_ID=2495
# HHA_EVACUATION_ZONE_ID=10003239
HHA_API_KEY=
HHA_USE_MOCK=true
# Set to true only after explicit go-live approval
HHA_ALLOW_PRODUCTION=false
# Sandbox cannot read confirm reason codes (-9); read from prod (read-only) for sandbox testing
HHA_ALLOW_REASON_LOOKUP=true
HHA_REASON_LOOKUP_URL=https://app.hhaexchange.com/Integration/ENT/V1.8/ws.asmx
HHA_REASON_LOOKUP_VISIT_ID=1308496385

# Local / pipeline
